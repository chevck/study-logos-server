PORT=3001

# Optional: comma-separated browser origins (e.g. https://app.example.com). If omitted, the server
# reflects the request Origin so local Vite (any port), LAN IP, and preview builds work with credentials.
# CORS_ORIGINS=http://localhost:5173,https://myapp.net

ANTHROPIC_API_KEY=your_key_here
# Must match a model ID from https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-haiku-4-5
BIBLE_API_KEY=your_key_here

# MongoDB Atlas — notebook persistence (put DB name in path before ? e.g. .../study-logos?...)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/study-logos?appName=Cluster0
# Optional if you omit the DB from the URI path (defaults to study-logos)
# MONGODB_DB_NAME=study-logos

# Breakdown cache (in-memory LRU) — reuse identical word+verse+translation+model without calling Anthropic
# BREAKDOWN_CACHE_MAX=400
# BREAKDOWN_CACHE_DISABLED=0

# Optional overrides (gitignored): server/.env.local — loaded last
# Optional: pin Bible IDs if auto-discovery fails for your API key
# BIBLE_ID_NKJV=
# BIBLE_ID_NLT=
# BIBLE_ID_AMP=
# BIBLE_ID_OYCB=
